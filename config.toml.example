[model]
provider = "bedrock"
model_id = "us.anthropic.claude-sonnet-4-6"
region = "us-east-1"
max_tokens = 8000

[agent]
token_threshold = 100000

[team]
poll_interval = 5
idle_timeout = 60

[paths]
skills_dir = "skills"
tasks_dir = ".tasks"
team_dir = ".team"
transcripts_dir = ".transcripts"
sessions_dir = ".sessions"

[logging]
level = "INFO"
file = "logs/agent.log"

[database]
host = "localhost"
port = 5432
user = ""
password = ""
dbname = "agent"

[memory]
enabled = false                              # set true to enable vector memory
embedding_model = "amazon.titan-embed-text-v2:0"
embedding_dimensions = 1024
max_results = 5
auto_save = true                             # auto-save exchanges to memory

[gateway]
channels = ["cli"]  # options: "cli", "telegram" — use ["telegram"] for headless mode

[telegram]
token = ""  # Get from @BotFather on Telegram

[dm_policy]
mode = "open"        # "open", "allowlist", "pairing"
allowlist = []       # user IDs allowed when mode = "allowlist"
pairing_code = ""    # code users must send when mode = "pairing"
