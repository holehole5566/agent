[model]
provider = "bedrock"
model_id = "us.anthropic.claude-sonnet-4-6"
region = "us-east-1"
max_tokens = 8000

[agent]
token_threshold = 100000

[team]
poll_interval = 5
idle_timeout = 60

[paths]
skills_dir = "skills"
team_dir = ".team"
transcripts_dir = ".transcripts"

[logging]
level = "INFO"
file = "logs/agent.log"

[database]
host = "localhost"
port = 5432
user = ""
password = ""
dbname = "agent"

[memory]
enabled = false
embedding_model = "amazon.titan-embed-text-v2:0"
embedding_dimensions = 1024
max_results = 5

[routines]
enabled = true
check_interval = 15

[gateway]
channels = ["cli"]  # options: "cli", "telegram" — use ["telegram"] for headless mode

[telegram]
token = ""       # Get from @BotFather on Telegram
owner_id = ""    # Set to your Telegram user ID to restrict access

[dm_policy]
mode = "open"        # "open", "allowlist", "pairing"
allowlist = []       # user IDs allowed when mode = "allowlist"
pairing_code = ""    # code users must send when mode = "pairing"
