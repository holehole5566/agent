# AWS Region (required)
AWS_REGION=us-east-1

# AWS credentials are loaded from standard sources:
#   - Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
#   - AWS credentials file (~/.aws/credentials)
#   - IAM role (EC2/ECS/Lambda)
#   - AWS SSO / AWS_PROFILE

# AWS_PROFILE=default

# Bedrock Model ID (required)
# Cross-region inference IDs use the "us." prefix
MODEL_ID=us.anthropic.claude-sonnet-4-6

# =============================================================================
#  Bedrock Model IDs
#
#  Model              Model ID
#  ----------------   -------------------------------------------
#  Claude Opus 4.6    us.anthropic.claude-opus-4-6
#  Claude Sonnet 4.6  us.anthropic.claude-sonnet-4-6
#  Claude Haiku 4.5   anthropic.claude-haiku-4-5-20251001-v1:0
#  Claude Sonnet 3.5  anthropic.claude-3-5-sonnet-20241022-v2:0
# =============================================================================
